+// Detects for joysticks and returns a count.
+
+int QNX_NumJoysticks(void){
+    struct joystick_hwdata* sticks = data_list;
+    int count = 0;
+
+    while(sticks){
+        count++;
+        sticks = sticks->next;
+    }
+
+    //fprintf(stderr, "qnx/joystick.c: | QNX_NumJoysticks: %d\n", count);
+    return count;
+}
