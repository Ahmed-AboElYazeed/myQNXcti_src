new file mode 100644
index 000000000..a5f6846aa
--- /dev/null
+++ b/src/video/qnx/mouse.c
@@ -0,0 +1,170 @@
+/*
+  Simple DirectMedia Layer
+  Copyright (C) 2017 BlackBerry Limited
+
