diff --git a/Makefile b/Makefile
index a3635d7..40b1fa6 100644
--- a/Makefile
+++ b/Makefile
@@ -4,7 +4,21 @@
 
 include config.mk
 
+# not sure if we need this if there is no way to generate pinfo files
+#ifeq("$(QNX_HOST)","/")
+define PINFO
+PINFO DESCRIPTION = Terminal emulator from suckless.org
+endef
+INSTALLDIR=
+NAME=st
+USEFILE=
+#endif
+
 SRC = st.c x.c main.c
+#ifeq("$(QNX_HOST)","/")
+SRC = st.c x.c screen.c main.c config.c
+#endif
+
 OBJ = $(SRC:.c=.o)
 
 all: st
diff --git a/config.mk b/config.mk
index fdc29a7..e66e276 100644
--- a/config.mk
+++ b/config.mk
@@ -5,10 +5,16 @@ VERSION = 0.9.2
 
 # paths
 PREFIX = /usr/local
+#ifeq("$(QNX_HOST)","/")
+PREFIX = /usr
+#endif
+
 MANPREFIX = $(PREFIX)/share/man
 
+#ifneq("$(QNX_HOST)","/")
 X11INC = /usr/X11R6/include
 X11LIB = /usr/X11R6/lib
+#endif
 
 PKG_CONFIG = pkg-config
 
@@ -19,11 +25,20 @@ INCS = -I$(X11INC) \
 LIBS = -L$(X11LIB) -lm -lrt -lX11 -lutil -lXft \
        `$(PKG_CONFIG) --libs fontconfig` \
        `$(PKG_CONFIG) --libs freetype2`
+#ifeq("$(QNX_HOST)","/")
+INCS =  \
+       `$(PKG_CONFIG) --cflags fontconfig` \
+       `$(PKG_CONFIG) --cflags freetype2`
+LIBS = -lm \
+        -rdynamic \
+        -lscreen -lcairo -lncurses -lz \
+       `$(PKG_CONFIG) --libs fontconfig`
+#endif
 
 # flags
 STCPPFLAGS = -DVERSION=\"$(VERSION)\" -D_XOPEN_SOURCE=600
 STCFLAGS = $(INCS) $(STCPPFLAGS) $(CPPFLAGS) $(CFLAGS)
-STLDFLAGS = $(LIBS) $(LDFLAGS)
+STLDFLAGS = $(LDFLAGS) $(LIBS)
 
 # OpenBSD:
 #CPPFLAGS = -DVERSION=\"$(VERSION)\" -D_XOPEN_SOURCE=600 -D_BSD_SOURCE
@@ -33,4 +48,5 @@ STLDFLAGS = $(LIBS) $(LDFLAGS)
 #MANPREFIX = ${PREFIX}/man
 
 # compiler and linker
+CC = gcc
 # CC = c99
